}

export default ProblemSection

const ProblemCard = ({
  icon,
  title,
  issues,
  color,
}: {
  icon: React.ReactElement
  title: string
  issues: Array<string>
  color: string
}) => {
  return (
    <GlassContainer className="flex h-full flex-col gap-6 rounded-3xl p-6">
      <div className="flex items-center gap-4">
        <GlassContainer className="flex min-h-15 min-w-15 items-center justify-center rounded-2xl border-white/15 text-white/80 ">
          {icon}
        </GlassContainer>
        <span className="text-sm font-semibold uppercase tracking-[0.28em] text-white/90">
          {title}
        </span>
      </div>
      <div className="flex flex-col gap-3 text-sm text-white/70">
        {issues.map((item) => (
          <div key={item} className="flex items-start gap-3">
            <LuBadgeInfo
              className="mt-0.5 text-white/40"
              size={16}
              color="red"
            />
            <span>{item}</span>
          </div>
        ))}
      </div>
    </GlassContainer>
  )
}
